# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5002
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# For local development: mongodb://127.0.0.1:27017/curriculum_planner
# For production: Use MongoDB Atlas connection string
MONGODB_URI=mongodb://127.0.0.1:27017/curriculum_planner

# ─── Authentication ───────────────────────────────────────────────────────────
# REQUIRED — Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Example: https://your-app.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ─── Email (Optional — falls back to console logging if not set) ──────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
